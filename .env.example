# Resend (Kontaktformular)
# API-Key aus https://resend.com/api-keys
RESEND_API_KEY=re_xxx

# Absender-Adresse. Muss zu einer in Resend verifizierten Domain gehören.
# Beispiel: "Kontaktformular <kontakt@schuetzen-buederich.de>"
CONTACT_FROM_EMAIL=

# Empfänger-Adresse (wohin Kontaktanfragen geschickt werden).
CONTACT_TO_EMAIL=

# PostHog (Analytics, nur nach Nutzer-Einwilligung aktiv)
# Projekt-API-Key aus https://eu.posthog.com (Project Settings → Project API Key)
NEXT_PUBLIC_POSTHOG_KEY=
# Optional: Host überschreiben (Default: https://eu.i.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
