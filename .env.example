# Resend (Kontaktformular)
# API-Key aus https://resend.com/api-keys
RESEND_API_KEY=re_xxx

# Absender-Adresse. Muss zu einer in Resend verifizierten Domain gehören.
# Beispiel: "Kontaktformular <kontakt@schuetzen-buederich.de>"
CONTACT_FROM_EMAIL=

# Empfänger-Adresse (wohin Kontaktanfragen geschickt werden).
CONTACT_TO_EMAIL=
